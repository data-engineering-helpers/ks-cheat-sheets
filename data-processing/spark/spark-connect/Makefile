#
# File: https://github.com/data-engineering-helpers/ks-cheat-sheets/blob/main/data-processing/spark/spark-connect/Makefile
#

PYTHON_VERSION := 3.12
# From Spark 4.0, Scala 2.13 is needed
SCALA_VERSION := 2.13
SPARK_VERSION := 4.1.1
DELTA_VERSION := 4.0.1

UV ?= uv

# Dates
TODAY_DATE := $(shell TZ=":Europe/Paris" date '+%Y-%m-%d')
NOW_TS := $(shell TZ=":Europe/Paris" date '+%Y-%m-%d %H:%M:%S %Z')

# ETL tasks
ETL_PYS := $(wildcard src/spark_connect_quickstart/0*.py)
ETL_TGTS := $(patsubst src/spark_connect_quickstart/0%.py,%,$(ETL_PYS))
ETL_TASKS := $(patsubst %,run-%,$(ETL_TGTS))

# Cleaners
clean-db: ## Clean database
	rm -rf derby.log metastore_db spark-warehouse

clean-logs: ## Clean log files
	rm -rf logs

clean-python: ## Clean Python-related objects
	find . -type f -name '*.py[co]' -delete
	find . -type d -name __pycache__ -delete
	rm -rf .mypy_cache
	rm -f requirements.txt

clean-package: ## Clean the project package.
	rm -rf dist/

clean-install: ## Clean the project installation.
	rm -rf .venv/

clean-pipelines: ## Clean SDP pipeline project
	rm -rf poc_pipeline

clean-sdp-data: ## Clean data generated by SDP
	rm -rf spark-warehouse/example_*_materialized_view

clean-datasets: ## Clean generated datasets
	rm -rf data/dim_customer/init data/dim_customer/inc1

cleaners: clean-db clean-logs clean-python clean-package clean-install clean-datasets ## Clean everything

# Initializers
init-uv-python: ## Install Python $(PYTHON_VERSION) if necessary
	uv python install $(PYTHON_VERSION)

init-pyspark: ## Install PySpark and Delta Lake in the current Python environment (not the uv virtual one)
	python -mpip install --force-reinstall \
		pyspark==$(SPARK_VERSION) delta-spark==$(DELTA_VERSION)

init-pipelines: ## Initialize SDP pipeline project
	@uv run spark-pipelines init --name poc_pipeline
	ls -lFh poc_pipeline

init-database: ## Initialize the Delta tables
	uv run spark-sql \
		--packages io.delta:delta-spark_$(SCALA_VERSION):$(DELTA_VERSION) \
		--conf "spark.sql.extensions=io.delta.sql.DeltaSparkSessionExtension" \
	  	--conf "spark.sql.catalog.spark_catalog=org.apache.spark.sql.delta.catalog.DeltaCatalog" \
	  < sql/ddl.sql
	echo "Delta table generated in spark-warehouse/dim_customer/"
	ls -lFh spark-warehouse/dim_customer/

$(ETL_TASKS): run-%: ## Run an ETL task
	@task=$* && \
	task_fp="src/spark_connect_quickstart/0$${task}.py" && \
	spark_version=$$(uv run pip show pyspark| grep "^Version"| cut -d" " -f2,2) && \
	dl_version=$$(uv run pip show delta-spark| grep "^Version"| cut -d" " -f2,2) && \
	echo "Task: 0$${task} - Spark version: $${spark_version} - Delta version: $${dl_version}" && \
	uv run pyspark < $${task_fp}

check-dataset-init: ## Analyze the initial data-set
	uv run datanomy data/dim_customer/init/part*.parquet

check-dataset-incremental: ## Analyze the incremental data-set
	uv run datanomy data/dim_customer/inc1/part*.parquet

#
init: ## Setup Python virtual environment
	@uv lock
	@uv export --format requirements.txt > requirements.txt

update: ## Update the dependencies
	@uv sync
	@uv export --format requirements.txt > requirements.txt

build: ## Build the software artifact (wheel)
	@uv build

# SDP
run-sdp: clean-sdp-data ## Execute the SDP pipeline
	@uv run spark-pipelines run --spec poc_pipeline/spark-pipeline.yml
	ls -lFh spark-warehouse/example_*_materialized_view

check-sdp-data-python: ## Analyze the data-set generated by the Python pipeline
	uv run datanomy spark-warehouse/example_python_materialized_view/part*.parquet

check-sdp-data-sql: ## Analyze the data-set generated by the SQL pipeline
	uv run datanomy spark-warehouse/example_sql_materialized_view/part*.parquet

#
check-database: ## Check the Delta tables
	uv run spark-sql \
		--packages io.delta:delta-spark_$(SCALA_VERSION):$(DELTA_VERSION) \
	  	--conf "spark.sql.extensions=io.delta.sql.DeltaSparkSessionExtension" \
	  	--conf "spark.sql.catalog.spark_catalog=org.apache.spark.sql.delta.catalog.DeltaCatalog" \
	  < sql/select-dim-customer-limit10.sql
	echo "Delta table generated in spark-warehouse/dim_customer/"
	ls -lFh spark-warehouse/dim_customer/

#
ingest-datasets: ## Ingest the customer-related datasets (initial and incremental)
	@echo "Check logs/ingest-datasets.log"
	mkdir -p logs
	time uv run spark-submit \
		--packages io.delta:delta-spark_$(SCALA_VERSION):$(DELTA_VERSION) \
	  	--conf "spark.sql.extensions=io.delta.sql.DeltaSparkSessionExtension" \
	  	--conf "spark.sql.catalog.spark_catalog=org.apache.spark.sql.delta.catalog.DeltaCatalog" \
	  src/004_sdp_quick_start/spark-merge-customer.py \
		> logs/ingest-datasets.log 2>&1
	echo "Delta table updated in spark-warehouse/dim_customer/"
	ls -lFh spark-warehouse/dim_customer/

